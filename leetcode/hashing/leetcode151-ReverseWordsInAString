class Solution {
public:
    string reverseWords(string s) {
        std::vector<std::string> words;
        string word,ans;
        stringstream ss(s);
        while(ss >> word)
        {
            words.push_back(word);
        }
        for(int i=words.size()-1;i>0;i--)
        {
            ans = ans + words[i] + " ";
        }
        ans = ans + words[0];
        return ans;
    }
};