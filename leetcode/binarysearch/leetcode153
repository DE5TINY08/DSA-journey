class Solution {
public:
    int findMin(vector<int>& nums) {
        int low = 0,high;
        high = nums.size() - 1;
        int mid;
        while(high>=low)
        {
            mid = low +(high - low)/2;
            if(nums[mid] < nums[high])
            {
                high = mid;
            }
            else
            {
                low = mid +1;
            }
        }
     return nums[mid];   
    }
};