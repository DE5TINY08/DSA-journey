class Solution {
public:
    int removeElement(vector<int>& nums, int val) {
        if (nums.empty())
        {
            return 0;
        }
        else
        {
            int k;
            for(k=0;k<nums.size();k++)
            {
                if(nums[k] == val)
                {
                    nums.erase(nums.begin() + k);
                    k--;
                }
            } return k;
        }

    }
};